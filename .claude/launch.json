{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "nifi",
      "runtimeExecutable": "powershell",
      "runtimeArgs": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "start_nifi_with_login.ps1"],
      "port": 8443,
      "autoPort": false
    },
    {
      "name": "jupyter",
      "runtimeExecutable": "jupyter",
      "runtimeArgs": ["notebook", "--notebook-dir=.", "--no-browser"],
      "port": 8888
    }
  ]
}
